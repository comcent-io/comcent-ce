SOURCE_EMAIL="Example <noreply@example.com>"
# Single source of truth for the public-facing URL. Apps derive PHX_HOST,
# SIP_USER_ROOT_DOMAIN, the SvelteKit public app base URL, and the SIP user
# domain shown in the UI from this. Override the individual vars only if you
# front-host pieces separately.
PUBLIC_BASE_URL=http://localhost:6173
# SBC serves SIP-over-WS directly (bypasses Traefik) — set explicitly.
PUBLIC_SIP_WS_URL=ws://localhost:6080/sip-ws
DATABASE_URL=replaceMe

STORAGE_BUCKET_NAME=comcent-storage-dev
RABBITMQ_URL=replaceMe
SERVER_SENTRY_DSN=replaceMe # Sentry DSN for Elixir Phoenix server
BUCKET_REGION=us-east-1
AWS_ACCESS_KEY_ID=replaceMe     # not required if you are using iam roles
AWS_SECRET_ACCESS_KEY=replaceMe # not required if you are using iam roles
S3_ENDPOINT_URL=http://minio:9000 # for local dev with docker-compose MinIO
S3_PROXY_DOWNLOADS=true
SIGNING_KEY=replaceMe
AUTH_PASSWORD_ENABLED=true
AUTH_OIDC_PROVIDERS_JSON={}
SMTP_URL=smtp://username:password@mail.example.com:587
INTERNAL_API_BASE_URL=replaceMe
INTERNAL_API_USERNAME=internal_api
INTERNAL_API_PASSWORD=replaceMe
OPENAI_FUNCTION_API_KEY=replaceMe # this is used during dev and integration test to see how voice bot uses api
DEEPGRAM_API_KEY=replaceMe
KAMAILIO_SIP_URI=replaceMe
OPENAI_API_KEY=replaceMe
ENV=replaceMe
FS_LOCAL_NETWORK=replaceMe                       # Any SIP request from this network will be considered local and use private ip for sip and rtp
REDIS_URL=redis://redis
DEV_IP=replaceMe # This is dev machine IP, used for local development
DEV_RABBITMQ_USERNAME=replaceMe
DEV_RABBITMQ_PASSWORD=replaceMe
RPC_API_TOKEN=replaceMe
KAMAILIO_IP=replaceMe
KAMAILIO_IPS=replaceMe
SECRET_KEY_BASE=replaceMe # used by phoenix library
CLUSTER_STRATEGY=replaceMe
