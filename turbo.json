{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build:watch"]
    },
    "build:watch": {
      "outputs": ["dist/**"]
    },
    "build": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  },
  "globalDependencies": [
    ".env",
    "tsconfig.json"
  ]
}
